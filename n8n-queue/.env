# n8n Queue Mode — Environment Variables

SUB_DOMAIN=n8n
DOMAIN=example.com

QUEUE_MODE=true

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

TZ=UTC
GENERIC_TIMEZONE=UTC

# Leave as "latest" to always get the latest stable
N8N_VERSION=latest

# Number of n8n-worker replicas. Recommended: floor(RAM_GB / 2)
N8N_WORKERS=2
