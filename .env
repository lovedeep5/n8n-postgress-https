# --- n8n encryption key (any 32-char random string is fine) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- Domain config ---
DOMAIN=example.com
SUB_DOMAIN=automation

# --- Timezone (IANA format, e.g. America/New_York, Europe/London, Asia/Kolkata) ---
TZ=UTC
GENERIC_TIMEZONE=UTC

# --- Queue mode (PostgreSQL + Redis + workers) ---
QUEUE_MODE=false

# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
REDIS_PASSWORD=
N8N_WORKERS=2
