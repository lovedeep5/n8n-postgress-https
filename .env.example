# n8n Queue Mode — Environment Variables
# Copy this file to .env and fill in your values

# --- Domain ---
SUB_DOMAIN=n8n
DOMAIN=example.com

# --- Mode (set to "true" to enable queue mode) ---
QUEUE_MODE=true

# --- Secrets (change these!) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# --- Timezone ---
TZ=UTC
GENERIC_TIMEZONE=UTC

# --- n8n Version ---
# Pin to a specific version for production (e.g., 1.80.3)
# Leave as "latest" to always get the latest stable
N8N_VERSION=latest

# --- Worker Count ---
# Number of n8n-worker replicas. Recommended: floor(RAM_GB / 2)
N8N_WORKERS=2